<!-- BJ Loan Services - Login & Sign Up (Single Page Tabs) -->
<!-- Save as login.html -->

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BJ Loan Services - Login</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:#f5f5f5;
    overflow:hidden;
    position:relative;
}

/* Background Curves */

body::before{
    content:'';
    position:absolute;
    top:-250px;
    left:-250px;
    width:600px;
    height:600px;
    background:#e00012;
    border-radius:50%;
}

body::after{
    content:'';
    position:absolute;
    bottom:-250px;
    right:-250px;
    width:600px;
    height:600px;
    background:#e00012;
    border-radius:50%;
}

/* Card */

.container{
    width:950px;
    background:white;
    border-radius:30px;
    overflow:hidden;
    display:flex;
    box-shadow:0 15px 40px rgba(0,0,0,0.12);
    z-index:2;
}

/* Left Panel */

.left-panel{
    width:40%;
    background:linear-gradient(135deg,#e00012,#ff2a2a);
    color:white;
    padding:60px 40px;
    text-align:center;
    display:flex;
    flex-direction:column;
    justify-content:center;
}

.left-panel img{
    width:120px;
    margin:0 auto 20px;
    background:white;
    border-radius:20px;
    padding:10px;
}

.left-panel h1{
    font-size:34px;
    margin-bottom:15px;
}

.left-panel p{
    line-height:1.8;
    opacity:.95;
}

/* Right Panel */

.right-panel{
    width:60%;
    padding:50px 60px;
}

/* Tabs */

.tabs{
    display:flex;
    margin-bottom:40px;
}

.tab-btn{
    flex:1;
    padding:15px;
    border:none;
    background:#f2f2f2;
    font-size:16px;
    font-weight:600;
    cursor:pointer;
    transition:.3s;
}

.tab-btn.active{
    background:#e00012;
    color:white;
}

/* Forms */

.form-box{
    display:none;
}

.form-box.active{
    display:block;
}

.form-box h2{
    color:#e00012;
    margin-bottom:10px;
}

.form-box p{
    color:#666;
    margin-bottom:30px;
}

.input-group{
    margin-bottom:20px;
}

.input-group input{
    width:100%;
    padding:15px 18px;
    border:1px solid #ddd;
    border-radius:12px;
    font-size:15px;
}

.input-group input:focus{
    border-color:#e00012;
    outline:none;
}

.row{
    display:flex;
    gap:15px;
}

.row .input-group{
    flex:1;
}

.extra{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:25px;
    font-size:14px;
}

.extra a{
    color:#e00012;
    text-decoration:none;
}

.submit-btn{
    width:100%;
    padding:15px;
    background:#e00012;
    color:white;
    border:none;
    border-radius:12px;
    font-size:16px;
    font-weight:600;
    cursor:pointer;
    transition:.3s;
}

.submit-btn:hover{
    background:#c70010;
}

.note{
    text-align:center;
    color:#777;
    margin-top:25px;
    font-size:13px;
}

@media(max-width:900px){

.container{
    flex-direction:column;
    width:95%;
}

.left-panel,
.right-panel{
    width:100%;
}

.left-panel{
    padding:40px 30px;
}

.right-panel{
    padding:40px 25px;
}

.row{
    flex-direction:column;
}
}
</style>
</head>

<body>

<div class="container">

    <!-- LEFT -->
    <div class="left-panel">

        <!-- Use your uploaded logo -->
        <img src="1000054126.png" alt="BJ Logo">

        <h1>BJ Loan Services</h1>

        <p>
            Your Loan, Our Commitment.<br><br>
            Fast approvals, secure documentation,
            and financial solutions designed around you.
        </p>

    </div>

    <!-- RIGHT -->
    <div class="right-panel">

        <!-- Tabs -->
        <div class="tabs">
            <button class="tab-btn active" onclick="showTab('login')">
                Login
            </button>

            <button class="tab-btn" onclick="showTab('signup')">
                Sign Up
            </button>
        </div>

        <!-- LOGIN -->
        <div class="form-box active" id="login">

            <h2>Welcome Back</h2>
            <p>Login to access your account.</p>

            <div class="input-group">
                <input type="email"
                       placeholder="Email Address">
            </div>

            <div class="input-group">
                <input type="password"
                       placeholder="Password">
            </div>

            <div class="extra">
                <label>
                    <input type="checkbox">
                    Remember me
                </label>

                <a href="#">
                    Forgot Password?
                </a>
            </div>

            <button class="submit-btn">
                Login
            </button>

        </div>

        <!-- SIGN UP -->
        <div class="form-box" id="signup">

            <h2>Create Account</h2>
            <p>Register for a new BJ Loan Services account.</p>

            <div class="row">

                <div class="input-group">
                    <input type="text"
                           placeholder="First Name">
                </div>

                <div class="input-group">
                    <input type="text"
                           placeholder="Last Name">
                </div>

            </div>

            <div class="input-group">
                <input type="email"
                       placeholder="Email Address">
            </div>

            <div class="input-group">
                <input type="tel"
                       placeholder="Mobile Number">
            </div>

            <div class="row">

                <div class="input-group">
                    <input type="password"
                           placeholder="Password">
                </div>

                <div class="input-group">
                    <input type="password"
                           placeholder="Confirm Password">
                </div>

            </div>

            <button class="submit-btn">
                Create Account
            </button>

        </div>

        <div class="note">
            Demo Portal • BJ Loan Services © 2026
        </div>

    </div>

</div>

<script>

function showTab(tab){

    const forms =
        document.querySelectorAll('.form-box');

    const buttons =
        document.querySelectorAll('.tab-btn');

    forms.forEach(form =>
        form.classList.remove('active'));

    buttons.forEach(btn =>
        btn.classList.remove('active'));

    document
        .getElementById(tab)
        .classList.add('active');

    event.target
        .classList.add('active');
}

</script>

</body>
</html>
